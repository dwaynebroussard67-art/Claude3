# Postgres connection string (Neon, Supabase, or Vercel Postgres all work)
DATABASE_URL=postgres://user:password@host:5432/dbname

# Free Hugging Face token (no credit card required)
# Get one at https://huggingface.co/settings/tokens — a "Read" token is enough.
HF_TOKEN=

# Optional: override the default chat model (see https://huggingface.co/models
# for other instruct/chat models available via Inference Providers)
# HF_MODEL=deepseek-ai/DeepSeek-V3-0324
